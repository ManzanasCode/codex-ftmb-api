{
  "name": "api-call-detector-service",
  "version": "1.0.0",
  "description": "Production-ready microservice to detect and extract XHR/fetch API calls from webpages",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json",
